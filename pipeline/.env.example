# ── Garmin Connect ────────────────────────────────────────────────────────────
GARMIN_EMAIL=tvoj@email.com
GARMIN_PASSWORD=tvoje_garmin_heslo

# ── Email ─────────────────────────────────────────────────────────────────────
# Gmail: zapni 2FA → myaccount.google.com → Security → App passwords → vygeneruj
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tvoj@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx    # 16-znakovy App Password (NIE normalne heslo!)
EMAIL_FROM=tvoj@gmail.com
EMAIL_TO=tvoj@email.com              # moze byt viacero oddelene ciarkou

# ── Ostatne ───────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
POLL_INTERVAL_MINUTES=30
RECOMPUTE_DFA=true
